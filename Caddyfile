# Canonical redirect: www -> apex. Keeps OAuth state/PKCE cookies and the
# Google/GitHub redirect_uri on a single origin, which fixes the intermittent
# "We had trouble linking that account" + Google 400 errors at sign-in
# (NEXTAUTH_URL is the apex, so cookies/callbacks must live on the apex too).
www.resumeai-bot.ru {
	redir https://resumeai-bot.ru{uri} permanent
}

resumeai-bot.ru {
	encode gzip

	header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

	# Strip /api/worker prefix and proxy to the Python FastAPI worker.
	# /api/worker/health  →  worker:8000/health
	# /api/worker/jobs/*  →  worker:8000/jobs/*
	handle_path /api/worker/* {
		reverse_proxy worker:8000
	}

	# Everything else goes to the Next.js app.
	reverse_proxy * web:3000

	log {
		output file /var/log/caddy/access.log {
			roll_size 50mb
			roll_keep 5
		}
		format json
	}
}
