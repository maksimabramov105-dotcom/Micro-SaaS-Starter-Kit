generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  apiKeys       ApiKey[]
  notifications Notification[]

  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?

  role          String    @default("user")
  permissions   String[]  @default(["read"])
  onboarded     Boolean   @default(false)
  onboardingStep Int      @default(0)
  usageCount    Int       @default(0)
  usageLimit    Int       @default(1000)
  credits       Int       @default(0)
  lastActiveAt  DateTime  @default(now())
  preferences   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ApiKey {
  id        String   @id @default(cuid())
  name      String
  key       String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastUsed  DateTime?
  createdAt DateTime @default(now())
  expiresAt DateTime?

  @@index([userId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  actionUrl String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([createdAt])
}

model Upload {
  id        String   @id @default(cuid())
  userId    String
  filename  String
  url       String
  size      Int
  mimeType  String
  key       String   @unique
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([key])
}

model UsageRecord {
  id        String   @id @default(cuid())
  userId    String
  teamId    String?
  feature   String
  quantity  Int      @default(1)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([teamId])
  @@index([feature])
  @@index([createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  teamId      String?
  action      String
  resource    String
  resourceId  String?
  changes     Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([teamId])
  @@index([resource, resourceId])
  @@index([createdAt])
}

model Invoice {
  id            String   @id @default(cuid())
  userId        String
  teamId        String?
  invoiceNumber String   @unique
  stripeInvoiceId String? @unique
  status        String   @default("draft")
  amount        Int
  currency      String   @default("usd")
  tax           Int      @default(0)
  items         Json
  paidAt        DateTime?
  dueDate       DateTime?
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([teamId])
  @@index([status])
  @@index([createdAt])
}

model AnalyticsEvent {
  id         String   @id @default(cuid())
  userId     String?
  sessionId  String?
  event      String
  properties Json?
  page       String?
  referrer   String?
  userAgent  String?
  ipAddress  String?
  country    String?
  city       String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([sessionId])
  @@index([event])
  @@index([createdAt])
}

model Consent {
  id        String   @id @default(cuid())
  userId    String
  type      String
  version   String
  accepted  Boolean  @default(false)
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@unique([userId, type, version])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model PasswordHistory {
  id           String   @id @default(cuid())
  userId       String
  passwordHash String
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model LoginAttempt {
  id         String   @id @default(cuid())
  email      String
  ipAddress  String
  userAgent  String?
  success    Boolean  @default(false)
  failReason String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([email])
  @@index([ipAddress])
  @@index([success])
  @@index([createdAt])
}

model DeviceSession {
  id          String   @id @default(cuid())
  userId      String
  deviceId    String
  deviceName  String?
  deviceType  String?
  browser     String?
  os          String?
  ipAddress   String
  location    String?
  lastActive  DateTime @default(now())
  trusted     Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([userId, deviceId])
  @@index([userId])
  @@index([deviceId])
  @@index([lastActive])
}
