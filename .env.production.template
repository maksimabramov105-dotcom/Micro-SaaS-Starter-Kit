# =============================================================================
# PRODUCTION ENVIRONMENT TEMPLATE
# Updated: 2026-05-15  (aligned with docker-compose.yml env key names)
# Fill every value before first deploy. Never commit filled values.
# Key names here MUST match docker-compose.yml exactly.
# =============================================================================

# --- Database (Postgres, required) ---
DATABASE_URL=                     # postgresql://user:pass@host:5432/resumeai

# --- Redis (BullMQ + ioredis, required) ---
REDIS_URL=                        # redis://user:pass@host:6379

# --- NextAuth ---
NEXTAUTH_URL=                     # https://yourdomain.com
NEXTAUTH_SECRET=                  # GENERATE FRESH: openssl rand -hex 32
                                  # Do NOT reuse legacy JWT_SECRET

# --- OAuth providers (at least one required) ---
# Key names read by lib/auth.ts — must match exactly
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_ID=                        # was GITHUB_CLIENT_ID in older docs — use GITHUB_ID
GITHUB_SECRET=                    # was GITHUB_CLIENT_SECRET in older docs — use GITHUB_SECRET

# --- Email (Resend) ---
RESEND_API_KEY=                   # REUSE: re_4oUBURHE_... from legacy .env
RESEND_FROM=                      # noreply@yourdomain.com

# --- Stripe ---
STRIPE_SECRET_KEY=                # REUSE: sk_live_... from legacy .env
STRIPE_PUBLIC_KEY=                # REUSE: pk_live_... from legacy .env (was STRIPE_PUBLISHABLE_KEY)
STRIPE_WEBHOOK_SECRET=            # REGENERATE — new endpoint URL changes this
                                  # Run: stripe listen --forward-to ... then copy

# Stripe price IDs — key names read by lib/pricing.ts and lib/subscription.ts
STRIPE_PRICE_ID_TRIAL=price_1TRBHbHH7N0YD11Qwx6owN7R       # $2.99 one-time, 14 days
STRIPE_PRICE_ID_PRO=price_1TRBHcHH7N0YD11Q2XMCZmbM          # $19.99/month
STRIPE_PRICE_ID_PRO_YEARLY=price_1TRBHcHH7N0YD11QLfWU0N46   # $191.90/year
STRIPE_PRICE_ID_UNLIMITED=price_1TRBHeHH7N0YD11Qumn5cvDB    # $29.99/month (Premium)
STRIPE_PRICE_ID_UNLIMITED_ANNUAL=price_1TRBHeHH7N0YD11QQwQq7rtO  # $287.90/year
STRIPE_PRICE_ID_BASIC=            # Basic tier monthly (if used)
STRIPE_PRICE_ID_BASIC_YEARLY=     # Basic tier yearly (if used)
STRIPE_PRICE_ID_ENTERPRISE=       # Enterprise tier monthly (if used)
STRIPE_PRICE_ID_ENTERPRISE_YEARLY= # Enterprise tier yearly (if used)

# --- AI (worker service) ---
OPENAI_API_KEY=                   # REUSE: sk-or-v1-... (OpenRouter) from legacy .env
                                  # Note: legacy uses OPENROUTER_API_KEY pointing to OpenRouter
OPENAI_MODEL=gpt-4o-mini          # Default: gpt-4o-mini

# --- Internal worker auth ---
WORKER_SECRET=                    # GENERATE FRESH: openssl rand -hex 32
                                  # Shared between Next.js and the Python worker

# --- Encryption (CRITICAL — must match legacy value) ---
ENCRYPTION_KEY=                   # ⚠️  REUSE VERBATIM from legacy .env
                                  # If changed, all stored LinkedIn passwords become unreadable

# --- App URL ---
NEXT_PUBLIC_APP_URL=              # https://yourdomain.com (same as NEXTAUTH_URL)

# --- Observability ---
NEXT_PUBLIC_SENTRY_DSN=           # From sentry.io project settings
SENTRY_ORG=                       # Sentry org slug
SENTRY_PROJECT=                   # Sentry project slug
SENTRY_AUTH_TOKEN=                # For source map uploads in CI

# --- Analytics (optional) ---
NEXT_PUBLIC_POSTHOG_KEY=          # REUSE: phx_... from legacy .env
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# --- Optional ---
TELEGRAM_BOT_TOKEN=               # REUSE from legacy .env (for admin notifications)
# ADMIN_WEBHOOK_URL=              # Slack/Discord webhook for smoke_test.sh alerts
#                                 # Set in GitHub Actions secrets, not here
