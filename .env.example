# Database
DATABASE_URL="postgresql://user:password@localhost:5432/microsaas?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-generate-with-openssl-rand-base64-32"

# Google OAuth (optional)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# GitHub OAuth (optional)
GITHUB_ID="your-github-client-id"
GITHUB_SECRET="your-github-client-secret"

# Stripe
STRIPE_PUBLIC_KEY="pk_test_your-stripe-public-key"
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"

# Stripe Price IDs
STRIPE_PRICE_ID_BASIC="price_your-basic-plan-id"
STRIPE_PRICE_ID_PRO="price_your-pro-plan-id"
STRIPE_PRICE_ID_ENTERPRISE="price_your-enterprise-plan-id"

# App Configuration
NEXT_PUBLIC_APP_NAME="ResumeAI"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# PMF dashboard — admin gate (comma-separated list of allowed emails)
ADMIN_EMAILS="founder@yourdomain.com"

# Cron authentication — set a long random secret, put the same in GitHub Actions secrets
CRON_SECRET="your-long-random-secret-here"

# Email (Resend)
RESEND_API_KEY="re_your-resend-api-key"
EMAIL_FROM="noreply@yourdomain.com"

# Error Tracking (Sentry)
NEXT_PUBLIC_SENTRY_DSN="your-sentry-dsn"
SENTRY_ORG="your-sentry-org"
SENTRY_PROJECT="your-sentry-project"

# Analytics (Vercel)
# Automatically enabled on Vercel deployments

# Redis (for background jobs and caching)
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD="" # Optional

# Feature Flags
ENABLE_BACKGROUND_JOBS="true"
ENABLE_ANALYTICS="true"
ENABLE_FEEDBACK="true"

# Security
PASSWORD_MIN_LENGTH="8"
MAX_LOGIN_ATTEMPTS="5"
LOCKOUT_DURATION_MINUTES="15"

# Compliance
COOKIE_CONSENT_VERSION="1.0.0"
TERMS_VERSION="1.0.0"
PRIVACY_VERSION="1.0.0"
