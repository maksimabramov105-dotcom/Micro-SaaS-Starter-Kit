# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in real values
# All variables below mirror the docker-compose.yml environment blocks exactly.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://resumeai:resumeai@localhost:5432/resumeai"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-min-32-chars"

# ── OAuth providers (at least one required) ───────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

GITHUB_ID="your-github-client-id"
GITHUB_SECRET="your-github-client-secret"

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY="re_your-resend-api-key"
RESEND_FROM="noreply@yourdomain.com"

# Resend inbound email webhook (set in Resend dashboard → Inbound)
RESEND_WEBHOOK_SECRET="whsec_your-resend-webhook-secret"
INBOX_DOMAIN="yourdomain.com"

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_PUBLIC_KEY="pk_test_your-stripe-public-key"
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_your-stripe-webhook-secret"

# Price IDs — create in Stripe Dashboard → Products
STRIPE_PRICE_ID_PRO="price_your-pro-plan-id"
STRIPE_PRICE_ID_UNLIMITED="price_your-unlimited-plan-id"

# ── Python worker ─────────────────────────────────────────────────────────────
# Shared secret between web and worker (generate with: openssl rand -hex 32)
WORKER_SECRET="your-worker-secret-min-32-chars"
WORKER_URL="http://localhost:8000"

# OpenAI (or compatible proxy, e.g. OpenRouter)
OPENAI_API_KEY="sk-your-openai-api-key"
OPENAI_MODEL="gpt-4o-mini"
# Override base URL if using a proxy (e.g. OpenRouter geo-bypass):
# OPENAI_BASE_URL="https://openrouter.ai/api"
OPENAI_BASE_URL="https://api.openai.com"

# Adzuna job board API (optional — silently skipped if absent)
ADZUNA_APP_ID="your-adzuna-app-id"
ADZUNA_APP_KEY="your-adzuna-app-key"

# ── Encryption ────────────────────────────────────────────────────────────────
# Used to encrypt LinkedIn passwords at rest (generate with: openssl rand -hex 32)
ENCRYPTION_KEY="your-encryption-key-exactly-64-hex-chars"

# ── Telegram notifications ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_BOT_USERNAME="your_bot_username"
# Generate with: openssl rand -hex 32 — set same value in Telegram webhook config
TELEGRAM_WEBHOOK_SECRET="your-telegram-webhook-secret"

# ── App public config ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="ResumeAI"

# ── Admin & cron ──────────────────────────────────────────────────────────────
# Comma-separated emails allowed to access /dashboard/admin
ADMIN_EMAILS="founder@yourdomain.com"

# Bearer token for GitHub Actions cron endpoints
# Generate with: openssl rand -hex 32
CRON_SECRET="your-cron-secret-min-32-chars"

# ── Error tracking (Sentry) ───────────────────────────────────────────────────
# Create separate Sentry projects (or use one project with different environments).
# Leave SENTRY_DSN_WORKER / SENTRY_DSN_NOTIFIER empty to silence those services.
NEXT_PUBLIC_SENTRY_DSN="https://your-key@oXXXXXX.ingest.sentry.io/XXXXXXX"
SENTRY_ORG="your-sentry-org-slug"
SENTRY_PROJECT="your-sentry-project-slug"
SENTRY_DSN_WORKER=""
SENTRY_DSN_NOTIFIER=""
